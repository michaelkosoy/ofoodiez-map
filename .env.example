# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Sheets ID for data
SHEET_ID=your_sheet_id_here

# Admin Secret for refreshing cache
ADMIN_SECRET=your_admin_secret_here

# Formspree Endpoint for submissions
FORMSPREE_ENDPOINT=your_formspree_endpoint_here

# ---- Instagram Automation ----
# Create a Meta App at https://developers.facebook.com
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Random string for webhook verification (must match what you set in Meta App Dashboard)
WEBHOOK_VERIFY_TOKEN=ofoodiez_ig_verify_2025

# Your server's public URL (needed for OAuth callback and webhooks)
BASE_URL=https://your-server-domain.com

# Flask secret key for sessions
SECRET_KEY=change-me-to-a-random-string

# Database URL for Instagram automation (defaults to SQLite)
IG_DATABASE_URL=sqlite:///instagram_automation.db

# ---- Telegram Bot Content Management ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here
GEMINI_API_KEY=your_gemini_api_key_here
